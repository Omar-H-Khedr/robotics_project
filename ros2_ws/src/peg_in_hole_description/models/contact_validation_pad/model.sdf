<?xml version="1.0"?>
<sdf version="1.9">
  <model name="contact_validation_pad">
    <static>true</static>
    <link name="contact_validation_pad_link">
      <pose>0 0 0.015 0 0 0</pose>

      <collision name="contact_validation_pad_collision">
        <geometry><box><size>0.16 0.05 0.03</size></box></geometry>
        <surface>
          <contact>
            <ode>
              <kp>200000</kp>
              <kd>20</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <sensor name="contact_validation_sensor" type="contact">
        <always_on>true</always_on>
        <update_rate>100.0</update_rate>
        <topic>/gazebo/contacts/validation</topic>
        <contact>
          <collision>contact_validation_pad_collision</collision>
        </contact>
      </sensor>

      <visual name="contact_validation_pad_visual">
        <geometry><box><size>0.16 0.05 0.03</size></box></geometry>
        <material>
          <ambient>0.80 0.22 0.18 1</ambient>
          <diffuse>0.92 0.32 0.22 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>
    </link>
  </model>
</sdf>
