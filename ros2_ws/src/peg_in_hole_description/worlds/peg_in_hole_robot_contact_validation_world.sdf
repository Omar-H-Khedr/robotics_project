<?xml version="1.0"?>
<sdf version="1.9">
  <world name="peg_in_hole_robot_contact_validation_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin name="gz::sim::systems::Physics" filename="ignition-gazebo-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands" filename="ignition-gazebo-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="ignition-gazebo-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Contact" filename="ignition-gazebo-contact-system"/>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic"/>

    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.72 0.74 0.76 1</background>
      <shadows>true</shadows>
    </scene>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material>
            <ambient>0.55 0.57 0.58 1</ambient>
            <diffuse>0.62 0.64 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Research Baseline v0.8 uses the same workcell and KUKA spawn pose as the
      working baseline. This world intentionally contains no KUKA robot model:
      the launch file spawns exactly one robot entity. The additional
      robot_contact_validation_pad sits on a dedicated stand so its coordinates
      are independent of tabletop placement ambiguity.
    -->
    <include>
      <name>work_table</name>
      <uri>model://work_table</uri>
      <pose>0.80 0 0 0 0 0</pose>
    </include>

    <include>
      <name>robot_pedestal</name>
      <uri>model://robot_pedestal</uri>
      <pose>0.80 -0.75 0.0 0 0 0</pose>
    </include>

    <include>
      <name>hole_fixture</name>
      <uri>model://hole_fixture</uri>
      <pose>0.52 -0.20 0.75 0 0 0</pose>
    </include>

    <include>
      <name>target_plate</name>
      <uri>model://target_plate</uri>
      <pose>0.52 -0.20 0.79 0 0 0</pose>
    </include>

    <include>
      <name>cylindrical_peg</name>
      <uri>model://cylindrical_peg</uri>
      <pose>0.72 -0.05 0.75 0 0 0</pose>
    </include>

    <model name="robot_contact_validation_stand">
      <static>true</static>
      <!--
        Dedicated validation stand near the measured final tool0 endpoint.
        The KUKA itself is not included in this world; launch spawns exactly one
        robot at the baseline pose. The stand is visual-only so the robot
        contact sensor sees only robot_contact_validation_pad_collision.
      -->
      <pose>1.03 -0.42 0 0 0 0</pose>
      <link name="robot_contact_validation_stand_link">
        <visual name="robot_contact_validation_stand_visual">
          <pose>0 0 0.48 0 0 0</pose>
          <geometry>
            <box>
              <size>0.10 0.10 0.96</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.33 0.34 1</ambient>
            <diffuse>0.50 0.51 0.52 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>
          </material>
        </visual>
        <visual name="robot_contact_validation_stand_mount_visual">
          <pose>0 0.075 0.98 0 0 0</pose>
          <geometry>
            <box>
              <size>0.06 0.20 0.06</size>
            </box>
          </geometry>
          <material>
            <ambient>0.30 0.31 0.32 1</ambient>
            <diffuse>0.48 0.49 0.50 1</diffuse>
            <specular>0.12 0.12 0.12 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="robot_contact_validation_pad">
      <static>false</static>
      <!--
        Validation-only compliant contact bumper for v1.8 low-force endpoint
        validation.

        The measured final tool0 endpoint is approximately
        world [1.027, -0.267, 1.108]. The measured pre-approach tool0 pose is
        approximately world [0.963, -0.212, 1.011]. This lightweight dynamic
        bumper is centered slightly beyond the measured final endpoint and kept
        clear of the pre-approach pose so the existing segmented approach
        reaches the target only in the final segments. It can move when touched,
        reducing peak force compared with the earlier static rigid patch.

        Expected Gazebo contact topic:
        /world/peg_in_hole_robot_contact_validation_world/model/robot_contact_validation_pad/link/robot_contact_validation_pad_link/sensor/robot_contact_validation_sensor/contact
      -->
      <pose>1.060 -0.295 1.140 0 0 0</pose>
      <link name="robot_contact_validation_pad_link">
        <gravity>false</gravity>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>2.083333e-05</ixx>
            <iyy>1.302083e-05</iyy>
            <izz>1.302083e-05</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="robot_contact_validation_pad_collision">
          <geometry>
            <box>
              <size>0.025 0.05 0.05</size>
            </box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>2500</kp>
                <kd>35</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.8</mu>
                <mu2>0.8</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <sensor name="robot_contact_validation_sensor" type="contact">
          <always_on>true</always_on>
          <update_rate>100.0</update_rate>
          <topic>/world/peg_in_hole_robot_contact_validation_world/model/robot_contact_validation_pad/link/robot_contact_validation_pad_link/sensor/robot_contact_validation_sensor/contact</topic>
          <contact>
            <collision>robot_contact_validation_pad_collision</collision>
          </contact>
        </sensor>

        <visual name="robot_contact_validation_pad_visual">
          <geometry>
            <box>
              <size>0.025 0.05 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0.18 0.04 1</ambient>
            <diffuse>1.00 0.32 0.06 1</diffuse>
            <specular>0.30 0.18 0.12 1</specular>
          </material>
        </visual>

        <visual name="robot_contact_validation_pad_center_marker">
          <pose>-0.017 0 0 0 0 0</pose>
          <geometry>
            <sphere>
              <radius>0.018</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.02 0.65 0.85 1</ambient>
            <diffuse>0.05 0.90 1.00 1</diffuse>
            <emissive>0.01 0.20 0.25 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <model name="measured_pre_approach_tool0_marker">
      <static>true</static>
      <!--
        Visual-only marker at the measured robot_contact_pre_approach tool0
        pose. This model intentionally has no collision and is not a contact
        object.
      -->
      <pose>0.963 -0.212 1.011 0 0 0</pose>
      <link name="measured_pre_approach_tool0_marker_link">
        <visual name="measured_pre_approach_tool0_marker_visual">
          <geometry>
            <sphere>
              <radius>0.025</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.02 0.20 1.00 1</ambient>
            <diffuse>0.05 0.35 1.00 1</diffuse>
            <emissive>0.01 0.08 0.45 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <model name="measured_final_tool0_marker">
      <static>true</static>
      <!--
        Visual-only marker at the measured v1.5 final tool0 endpoint. This
        model intentionally has no collision and is not a contact object.
      -->
      <pose>1.027 -0.267 1.108 0 0 0</pose>
      <link name="measured_final_tool0_marker_link">
        <visual name="measured_final_tool0_marker_visual">
          <geometry>
            <sphere>
              <radius>0.025</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.00 1.00 0.10 1</ambient>
            <diffuse>0.00 1.00 0.10 1</diffuse>
            <emissive>0.00 0.60 0.06 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <light name="key_area_light" type="point">
      <pose>0.20 -0.60 1.80 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.4</intensity>
      <diffuse>0.95 0.95 0.90 1</diffuse>
      <specular>0.35 0.35 0.35 1</specular>
      <attenuation>
        <range>5.0</range>
        <constant>0.6</constant>
        <linear>0.15</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>0.8</intensity>
      <direction>-0.4 0.2 -0.9</direction>
      <diffuse>0.80 0.82 0.85 1</diffuse>
      <specular>0.20 0.20 0.20 1</specular>
    </light>
  </world>
</sdf>
