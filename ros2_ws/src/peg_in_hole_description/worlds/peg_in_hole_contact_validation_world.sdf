<?xml version="1.0"?>
<sdf version="1.9">
  <world name="peg_in_hole_contact_validation_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin name="gz::sim::systems::Physics" filename="ignition-gazebo-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands" filename="ignition-gazebo-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="ignition-gazebo-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Contact" filename="ignition-gazebo-contact-system"/>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic"/>

    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.72 0.74 0.76 1</background>
      <shadows>true</shadows>
    </scene>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material>
            <ambient>0.55 0.57 0.58 1</ambient>
            <diffuse>0.62 0.64 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Real-scale KUKA LBR iisy 3 R760 workcell.
      The robot is spawned by thesis_bringup without scaling. The table work
      surface is at z=0.75 m. A floor-mounted robot spawn at z=0.0 made the
      arm appear under the table even when x/y alignment was correct, so the
      research baseline is pedestal-mounted: base_link at
      [x=0.80, y=-0.75, z=0.75] with yaw=1.5708 rad. The x=0.80 coordinate
      aligns the robot with the table centerline.

      Robot-cell coordinate layout:
      - World +X runs along the table depth.
      - World +Y runs from the robot base toward the table.
      - Z is vertical, with the table work surface at z=0.75 m.

      Table pose: the 0.80 m x 0.60 m table is centered at [0.8, 0.0, 0.0],
      putting the robot-side tabletop edge at y=-0.30 m. With the robot base
      at [x=0.80, y=-0.75], the base is aligned with the table centerline and
      remains outside the table footprint.

      Task workspace: the peg, fixture, target plate, and nominal hole region
      sit on the robot-side area of the tabletop. Their z origins match the
      support stack: table surface at 0.75 m, fixture bottom at 0.75 m, and
      target plate bottom at 0.79 m.
    -->
    <include>
      <name>work_table</name>
      <uri>model://work_table</uri>
      <pose>0.80 0 0 0 0 0</pose>
    </include>

    <!-- Static 0.75 m pedestal under the KUKA base for the research baseline. -->
    <include>
      <name>robot_pedestal</name>
      <uri>model://robot_pedestal</uri>
      <pose>0.80 -0.75 0.0 0 0 0</pose>
    </include>

    <!-- Fixture base sits on the 0.75 m table surface and is 40 mm tall. -->
    <include>
      <name>hole_fixture</name>
      <uri>model://hole_fixture</uri>
      <pose>0.52 -0.20 0.75 0 0 0</pose>
    </include>

    <!-- Target plate sits on top of the fixture: z=0.79 m bottom, z=0.81 m top. -->
    <include>
      <name>target_plate</name>
      <uri>model://target_plate</uri>
      <pose>0.52 -0.20 0.79 0 0 0</pose>
    </include>

    <!-- Peg origin is at the table surface; its link offset places the 110 mm peg above the table. -->
    <include>
      <name>cylindrical_peg</name>
      <uri>model://cylindrical_peg</uri>
      <pose>0.72 -0.05 0.75 0 0 0</pose>
    </include>

    <!--
      Research Baseline v0.4 passive contact-probe validation.
      This setup is isolated on the far side of the table and does not require
      the KUKA to move or touch any object. The dynamic probe falls under
      gravity onto the instrumented pad to validate Gazebo contact sensing,
      ROS/Gazebo bridging, contact_metrics_node, and experiment logging.
    -->
    <model name="contact_validation_pad">
      <static>true</static>
      <pose>0.20 0.45 0.765 0 0 0</pose>
      <link name="contact_validation_pad_link">
        <pose>0 0 0.015 0 0 0</pose>

        <collision name="contact_validation_pad_collision">
          <geometry>
            <box>
              <size>0.20 0.20 0.03</size>
            </box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>200000</kp>
                <kd>20</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.8</mu>
                <mu2>0.8</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <sensor name="contact_validation_sensor" type="contact">
          <always_on>true</always_on>
          <update_rate>100.0</update_rate>
          <topic>/gazebo/contacts/validation</topic>
          <contact>
            <collision>contact_validation_pad_collision</collision>
          </contact>
        </sensor>

        <visual name="contact_validation_pad_visual">
          <geometry>
            <box>
              <size>0.20 0.20 0.03</size>
            </box>
          </geometry>
          <material>
            <ambient>0.00 0.55 0.42 1</ambient>
            <diffuse>0.00 0.78 0.58 1</diffuse>
            <specular>0.18 0.18 0.18 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="contact_probe">
      <static>false</static>
      <pose>0.20 0.45 0.835 0 0 0</pose>
      <link name="contact_probe_link">
        <gravity>true</gravity>
        <inertial>
          <mass>0.10</mass>
          <inertia>
            <ixx>0.000064</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.000064</iyy>
            <iyz>0</iyz>
            <izz>0.000064</izz>
          </inertia>
        </inertial>

        <collision name="contact_probe_collision">
          <geometry>
            <sphere>
              <radius>0.04</radius>
            </sphere>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>200000</kp>
                <kd>20</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.6</mu>
                <mu2>0.6</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="contact_probe_visual">
          <geometry>
            <sphere>
              <radius>0.04</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.95 0.84 0.10 1</ambient>
            <diffuse>1.00 0.90 0.18 1</diffuse>
            <specular>0.25 0.25 0.25 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <light name="key_area_light" type="point">
      <pose>0.20 -0.60 1.80 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.4</intensity>
      <diffuse>0.95 0.95 0.90 1</diffuse>
      <specular>0.35 0.35 0.35 1</specular>
      <attenuation>
        <range>5.0</range>
        <constant>0.6</constant>
        <linear>0.15</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>0.8</intensity>
      <direction>-0.4 0.2 -0.9</direction>
      <diffuse>0.80 0.82 0.85 1</diffuse>
      <specular>0.20 0.20 0.20 1</specular>
    </light>
  </world>
</sdf>
