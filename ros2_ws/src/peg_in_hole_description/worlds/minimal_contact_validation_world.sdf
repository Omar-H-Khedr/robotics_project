<?xml version="1.0"?>
<sdf version="1.9">
  <world name="minimal_contact_validation_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <gravity>0 0 -9.81</gravity>

    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.72 0.74 0.76 1</background>
      <shadows>true</shadows>
    </scene>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.48 0.50 0.51 1</ambient>
            <diffuse>0.62 0.64 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <light name="key_light" type="directional">
      <pose>0 0 4 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.0</intensity>
      <direction>-0.4 0.2 -0.9</direction>
      <diffuse>0.90 0.92 0.95 1</diffuse>
      <specular>0.25 0.25 0.25 1</specular>
    </light>

    <model name="contact_validation_pad">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="pad_link">
        <collision name="contact_validation_pad_collision">
          <geometry>
            <box>
              <size>0.5 0.5 0.1</size>
            </box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>200000</kp>
                <kd>20</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.8</mu>
                <mu2>0.8</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="contact_validation_pad_visual">
          <geometry>
            <box>
              <size>0.5 0.5 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.00 0.45 0.62 1</ambient>
            <diffuse>0.00 0.70 0.95 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>
          </material>
        </visual>

        <sensor name="contact_validation_sensor" type="contact">
          <always_on>true</always_on>
          <update_rate>100</update_rate>
          <topic>/gazebo/contacts/validation</topic>
          <contact>
            <collision>contact_validation_pad_collision</collision>
          </contact>
        </sensor>
      </link>
    </model>

    <model name="contact_probe">
      <static>false</static>
      <pose>0 0 0.175 0 0 0</pose>
      <link name="contact_probe_link">
        <gravity>true</gravity>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.000256</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.000256</iyy>
            <iyz>0</iyz>
            <izz>0.000256</izz>
          </inertia>
        </inertial>

        <collision name="contact_probe_collision">
          <geometry>
            <sphere>
              <radius>0.08</radius>
            </sphere>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>200000</kp>
                <kd>20</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.6</mu>
                <mu2>0.6</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="contact_probe_visual">
          <geometry>
            <sphere>
              <radius>0.08</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.92 0.12 0.18 1</ambient>
            <diffuse>1.00 0.18 0.24 1</diffuse>
            <specular>0.25 0.25 0.25 1</specular>
          </material>
        </visual>
      </link>
    </model>
  </world>
</sdf>
