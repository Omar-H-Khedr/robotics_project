<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="research_parallel_gripper" params="prefix parent_link tcp_frame:=gripper_tcp">
    <xacro:property name="gripper_palm_x" value="0.080"/>
    <xacro:property name="gripper_palm_y" value="0.060"/>
    <xacro:property name="gripper_palm_z" value="0.030"/>
    <xacro:property name="gripper_finger_x" value="0.018"/>
    <xacro:property name="gripper_finger_y" value="0.012"/>
    <xacro:property name="gripper_finger_z" value="0.090"/>
    <xacro:property name="gripper_finger_y_offset" value="0.031"/>
    <xacro:property name="gripper_finger_z_offset" value="0.075"/>
    <xacro:property name="gripper_tcp_z_offset" value="0.125"/>

    <material name="${prefix}research_gripper_dark">
      <color rgba="0.08 0.09 0.10 1.0"/>
    </material>
    <material name="${prefix}research_gripper_finger">
      <color rgba="0.78 0.78 0.72 1.0"/>
    </material>

    <link name="${prefix}gripper_palm">
      <inertial>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <mass value="0.35"/>
        <inertia ixx="0.000131" ixy="0.0" ixz="0.0" iyy="0.000213" iyz="0.0" izz="0.000292"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_palm_x} ${gripper_palm_y} ${gripper_palm_z}"/>
        </geometry>
        <material name="${prefix}research_gripper_dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_palm_x} ${gripper_palm_y} ${gripper_palm_z}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}flange_to_gripper_palm" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}gripper_palm"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}gripper_left_finger">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.08"/>
        <inertia ixx="0.000055" ixy="0.0" ixz="0.0" iyy="0.000056" iyz="0.0" izz="0.000004"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_finger_x} ${gripper_finger_y} ${gripper_finger_z}"/>
        </geometry>
        <material name="${prefix}research_gripper_finger"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_finger_x} ${gripper_finger_y} ${gripper_finger_z}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}gripper_palm_to_left_finger" type="fixed">
      <parent link="${prefix}gripper_palm"/>
      <child link="${prefix}gripper_left_finger"/>
      <origin xyz="0 ${gripper_finger_y_offset} ${gripper_finger_z_offset}" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}gripper_right_finger">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.08"/>
        <inertia ixx="0.000055" ixy="0.0" ixz="0.0" iyy="0.000056" iyz="0.0" izz="0.000004"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_finger_x} ${gripper_finger_y} ${gripper_finger_z}"/>
        </geometry>
        <material name="${prefix}research_gripper_finger"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${gripper_finger_x} ${gripper_finger_y} ${gripper_finger_z}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}gripper_palm_to_right_finger" type="fixed">
      <parent link="${prefix}gripper_palm"/>
      <child link="${prefix}gripper_right_finger"/>
      <origin xyz="0 ${-gripper_finger_y_offset} ${gripper_finger_z_offset}" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}${tcp_frame}"/>
    <joint name="${prefix}gripper_palm_to_${tcp_frame}" type="fixed">
      <parent link="${prefix}gripper_palm"/>
      <child link="${prefix}${tcp_frame}"/>
      <origin xyz="0 0 ${gripper_tcp_z_offset}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>
</robot>
